{
  "name": "carthage-software/php-toolchain-benchmarks",
  "description": "Benchmark suite for PHP formatters, linters, and static analyzers",
  "license": "MIT",
  "require": {
    "php": "~8.5.0",
    "php-standard-library/php-standard-library": "^6.1.0"
  },
  "autoload": {
    "psr-4": {
      "CarthageSoftware\\ToolChainBenchmarks\\": "src/"
    }
  },
  "config": {
    "platform-check": false,
    "sort-packages": true
  }
}
